# Unreal Engine .gitignore for RogosMobile

# Visual Studio / Visual Studio Code
.vs/
.vscode/
*.sln
*.suo
*.xcodeproj
*.xcworkspace
*.VC.db
*.VC.VC.opendb
*.vsconfig

# Compiled Object files
*.o
*.obj
*.slo
*.lo
*.a
*.lib
*.so
*.dll
*.dylib
*.exe
*.out
*.app
*.ipa
*.pdb

# Unreal Engine Build Artifacts (NOT versioned - auto-generated by engine)
Binaries/
Intermediate/
DerivedDataCache/
Build/
Saved/

# Precompiled Assets
*_BuiltData.uasset

# Crash Reports and Logs
*.log
*.tmp

# Configuration Cache
Saved/Config/Crashes/
Saved/Config/CrashReportClient/
Saved/Logs/

# User-specific files
*.user
*.userprefs
*.pidb
*.booproj

# MacOS
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Android/IOS build artifacts (root level only)
/[Aa]ndroid/
/[Ii]OS/

# Exceptions - KEEP these files (they are needed)
!Build/**/*.png
!Build/**/*.ico
!Build/**/PakBlacklist*.txt

# Rider IDE
.idea/

# Python
__pycache__/
*.py[cod]

# Claude Code — personal/machine-local settings (keep shared .claude/settings.json if added)
.claude/settings.local.json
